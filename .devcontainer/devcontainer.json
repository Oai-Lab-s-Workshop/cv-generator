{
  "name": "CV Generator",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/node:1": { "version": "20" }
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "forwardPorts": [4200, 8090],
  "portsAttributes": {
    "4200": { "label": "Angular", "onAutoForward": "openPreview" },
    "8090": { "label": "PocketBase", "onAutoForward": "silent" }
  },
  "customizations": {
    "vscode": {
      "extensions": ["angular.ng-template", "ms-azuretools.vscode-docker"]
    }
  }
}
